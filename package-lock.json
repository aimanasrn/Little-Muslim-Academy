{
  "name": "little-muslim-academy",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "little-muslim-academy",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/api": {
      "name": "@little-muslim/api"
    },
    "apps/web": {
      "name": "@little-muslim/web"
    },
    "node_modules/@little-muslim/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@little-muslim/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@little-muslim/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/shared": {
      "name": "@little-muslim/shared"
    }
  }
}
