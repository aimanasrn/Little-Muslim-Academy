generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  admin
  parent
}

enum AccessState {
  preview
  active
}

enum PublishStatus {
  draft
  published
  archived
}

enum PaymentStatus {
  initiated
  pending
  paid
  failed
  expired
  refunded
}

model User {
  id                String         @id @default(uuid())
  fullName          String
  email             String         @unique
  passwordHash      String
  role              Role           @default(parent)
  accessState       AccessState    @default(preview)
  preferredLanguage String         @default("ms")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  childProfiles     ChildProfile[]
  payments          Payment[]
  progressRecords   Progress[]
}

model ChildProfile {
  id          String     @id @default(uuid())
  userId      String
  displayName String
  birthMonth  Int?
  birthYear   Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress    Progress[]
}

model Module {
  id            String        @id @default(uuid())
  slug          String        @unique
  titleMs       String
  titleEn       String
  descriptionMs String
  descriptionEn String
  status        PublishStatus @default(published)
  isPreviewable Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lessons       Lesson[]
}

model Lesson {
  id            String        @id @default(uuid())
  moduleId      String
  slug          String        @unique
  titleMs       String
  titleEn       String
  descriptionMs String
  descriptionEn String
  isPreview     Boolean       @default(false)
  orderIndex    Int
  status        PublishStatus @default(published)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  module        Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress      Progress[]
}

model Payment {
  id          String        @id @default(uuid())
  userId      String
  provider    String
  providerRef String?       @unique
  amountCents Int
  currency    String        @default("MYR")
  status      PaymentStatus @default(initiated)
  checkoutUrl String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Progress {
  id             String       @id @default(uuid())
  userId         String
  childProfileId String
  lessonId       String
  completed      Boolean      @default(false)
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  lesson         Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([childProfileId, lessonId])
}
